# Hugo build output and caches
/public/
/resources/_gen/
.hugo_build.lock

# exampleSite build output (regenerated by `hugo -s exampleSite`)
/exampleSite/public/
/exampleSite/resources/

# Pagefind search index (regenerated by `pagefind --site <public>`)
/exampleSite/public/pagefind/

# Drafts, archive and competition entries — kept locally, outside the theme
# product. Never committed.
/local/

# OS junk
.DS_Store
